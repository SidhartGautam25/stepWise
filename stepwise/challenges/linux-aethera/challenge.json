{
  "schemaVersion": 1,
  "id": "linux-aethera",
  "version": "1.0.0",
  "title": "Intro to Linux",
  "language": "bash",
  "runtime": "web-terminal",
  "mode": "web",
  "capabilities": [
    "interactive-sequence",
    "sim-terminal",
    "quest-evaluator"
  ],
  "description": "Learn the first Linux filesystem commands with a visual directory and file explorer.",
  "steps": [
    {
      "id": "00-welcome",
      "title": "Why Learn Linux This Way",
      "prompt": "prompt.md",
      "explanation": "explanation.md",
      "requiresTerminal": false,
      "interactiveLesson": {
        "type": "sequence",
        "content": "interactive-sequence.json"
      },
      "workspace": {},
      "tests": {}
    },
    {
      "id": "00-why-os",
      "title": "Storage — Where Your Stuff Lives",
      "prompt": "prompt.md",
      "explanation": "explanation.md",
      "requiresTerminal": false,
      "interactiveLesson": {
        "type": "sequence",
        "content": "interactive-sequence.json"
      },
      "workspace": {},
      "tests": {}
    },
    {
      "id": "00-orientation",
      "title": "How to Read the Visualizer",
      "prompt": "prompt.md",
      "explanation": "explanation.md",
      "requiresTerminal": true,
      "completion": {
        "all": [
          { "type": "command_exact", "command": "continue" }
        ]
      },
      "workspace": {},
      "tests": {}
    },
    {
      "id": "01-directories",
      "title": "Directories and Listing",
      "prompt": "prompt.md",
      "explanation": "explanation.md",
      "requiresTerminal": true,
      "completion": {
        "all": [
          { "type": "vfs_dir_exists", "path": "/home/student/projects" },
          { "type": "command_exact", "command": "pwd" },
          { "type": "command_count_gte", "command": "ls", "count": 2 },
          { "type": "command_exact", "command": "mkdir projects" }
        ]
      },
      "workspace": {},
      "tests": {}
    },
    {
      "id": "02-navigation",
      "title": "Moving Between Directories",
      "prompt": "prompt.md",
      "explanation": "explanation.md",
      "requiresTerminal": true,
      "completion": {
        "all": [
          { "type": "vfs_dir_exists", "path": "/home/student/projects" },
          { "type": "cwd_is", "path": "/home/student/projects" },
          { "type": "command_exact", "command": "cd projects" },
          { "type": "command_exact", "command": "pwd" },
          { "type": "command_prefix", "prefix": "cd .." }
        ]
      },
      "workspace": {},
      "tests": {}
    },
    {
      "id": "03-files-and-listing",
      "title": "Files, Content, and Listing",
      "prompt": "prompt.md",
      "explanation": "explanation.md",
      "requiresTerminal": true,
      "completion": {
        "all": [
          { "type": "vfs_file_contains", "path": "/home/student/projects/notes.txt", "text": "hello linux" },
          { "type": "cwd_is", "path": "/home/student/projects" },
          { "type": "command_exact", "command": "touch notes.txt" },
          { "type": "command_prefix", "prefix": "echo hello linux > notes.txt" },
          { "type": "command_exact", "command": "ls" },
          { "type": "command_exact", "command": "cat notes.txt" }
        ]
      },
      "workspace": {},
      "tests": {}
    }
  ]
}
